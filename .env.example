# DataFlow environment variables — copy to .env and fill in values
# cp .env.example .env
#
# All alert email variables are OPTIONAL — DataFlow works without them.
# Pipelines log alerts to console if email is not configured.

# ── Optional email alerts ────────────────────────────────────────────────────
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── API base URL (used by dashboard to trigger pipelines remotely) ─────────
# Leave as localhost for local dev; change to Render URL for production
DATAFLOW_API_URL=http://localhost:8000
